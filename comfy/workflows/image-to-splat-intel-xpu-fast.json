{
  "1": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "splatbench_sample.png"
    },
    "_meta": {
      "title": "Input image"
    }
  },
  "2": {
    "class_type": "LoadBackgroundRemovalModel",
    "inputs": {
      "bg_removal_name": "birefnet.safetensors"
    },
    "_meta": {
      "title": "Load BiRefNet"
    }
  },
  "3": {
    "class_type": "RemoveBackground",
    "inputs": {
      "bg_removal_model": [
        "2",
        0
      ],
      "image": [
        "1",
        0
      ]
    },
    "_meta": {
      "title": "Foreground mask"
    }
  },
  "4": {
    "class_type": "TripoSplatPreprocessImage",
    "inputs": {
      "image": [
        "1",
        0
      ],
      "mask": [
        "3",
        0
      ],
      "erode_radius": 1,
      "size": 1024
    },
    "_meta": {
      "title": "TripoSplat image preprocess"
    }
  },
  "5": {
    "class_type": "CLIPVisionLoader",
    "inputs": {
      "clip_name": "dino_v3_vit_h.safetensors"
    },
    "_meta": {
      "title": "Load DINOv3"
    }
  },
  "6": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "flux2-vae.safetensors"
    },
    "_meta": {
      "title": "Load FLUX.2 VAE"
    }
  },
  "7": {
    "class_type": "TripoSplatConditioning",
    "inputs": {
      "clip_vision": [
        "5",
        0
      ],
      "vae": [
        "6",
        0
      ],
      "image": [
        "4",
        0
      ]
    },
    "_meta": {
      "title": "TripoSplat conditioning"
    }
  },
  "8": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "triposplat_fp16.safetensors",
      "weight_dtype": "default"
    },
    "_meta": {
      "title": "Load TripoSplat diffusion model"
    }
  },
  "9": {
    "class_type": "KSampler",
    "inputs": {
      "model": [
        "8",
        0
      ],
      "positive": [
        "7",
        0
      ],
      "negative": [
        "7",
        1
      ],
      "latent_image": [
        "7",
        2
      ],
      "seed": 123456789,
      "steps": 15,
      "cfg": 3,
      "sampler_name": "dpmpp_2m",
      "scheduler": "simple",
      "denoise": 1
    },
    "_meta": {
      "title": "Sample TripoSplat latent"
    }
  },
  "10": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "triposplat_vae_decoder_fp16.safetensors"
    },
    "_meta": {
      "title": "Load TripoSplat VAE decoder"
    }
  },
  "11": {
    "class_type": "VAEDecodeTripoSplat",
    "inputs": {
      "samples": [
        "9",
        0
      ],
      "vae": [
        "10",
        0
      ],
      "num_gaussians": 65536,
      "seed": 123456789
    },
    "_meta": {
      "title": "Decode Gaussian splat"
    }
  },
  "12": {
    "class_type": "SplatToFile3D",
    "inputs": {
      "splat": [
        "11",
        0
      ],
      "format": "spz"
    },
    "_meta": {
      "title": "Create SPZ file"
    }
  },
  "13": {
    "class_type": "SaveGLB",
    "inputs": {
      "mesh": [
        "12",
        0
      ],
      "filename_prefix": "triposplat/splatbench"
    },
    "_meta": {
      "title": "Save 3D output"
    }
  }
}
